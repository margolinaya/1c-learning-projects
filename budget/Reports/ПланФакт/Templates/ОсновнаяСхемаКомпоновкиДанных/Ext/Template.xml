			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Обязательная статья</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ЕСТЬNULL(ФактБюджета.Месяц, ПланБюджетаРССрезПоследних.Период) КАК Период,
	ВЫБОР
		КОГДА ПланБюджетаРССрезПоследних.Статья ЕСТЬ NULL
			ТОГДА ФактБюджета.Статья
		ИНАЧЕ ПланБюджетаРССрезПоследних.Статья
	КОНЕЦ КАК Статья,
	ЕСТЬNULL(МАКСИМУМ(ПланБюджетаРССрезПоследних.СуммаПлан), 0) КАК СуммаПлан,
	ЕСТЬNULL(СУММА(ФактБюджета.СуммаФакт), 0) КАК СуммаФакт,
	ВЫБОР
		КОГДА ЕСТЬNULL(СУММА(ФактБюджета.СуммаФакт), 0) - ЕСТЬNULL(МАКСИМУМ(ПланБюджетаРССрезПоследних.СуммаПлан), 0) &gt; 0
			ТОГДА ВЫБОР
					КОГДА ЕСТЬNULL(МАКСИМУМ(ПланБюджетаРССрезПоследних.СуммаПлан), 0) &gt; 0
						ТОГДА ЕСТЬNULL(СУММА(ФактБюджета.СуммаФакт), 0) * 100 / ЕСТЬNULL(МАКСИМУМ(ПланБюджетаРССрезПоследних.СуммаПлан), 0)
					ИНАЧЕ "100%"
				КОНЕЦ
		ИНАЧЕ "нет"
	КОНЕЦ КАК Перерасход,
	ВЫБОР
		КОГДА ПланБюджетаРССрезПоследних.Статья ЕСТЬ NULL
			ТОГДА ФактБюджета.Статья.Обязательная
		ИНАЧЕ ПланБюджетаРССрезПоследних.Статья.Обязательная
	КОНЕЦ КАК ОбязательнаяСтатья
ИЗ
	РегистрСведений.ПланБюджетаРС.СрезПоследних(, ) КАК ПланБюджетаРССрезПоследних
		ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.ФактБюджета КАК ФактБюджета
		ПО ПланБюджетаРССрезПоследних.Период = ФактБюджета.Месяц
			И ПланБюджетаРССрезПоследних.Статья = ФактБюджета.Статья
ГДЕ
	ЕСТЬNULL(ФактБюджета.Месяц, ПланБюджетаРССрезПоследних.Период) МЕЖДУ НАЧАЛОПЕРИОДА(&amp;Период, МЕСЯЦ) И КОНЕЦПЕРИОДА(&amp;Период, МЕСЯЦ)

СГРУППИРОВАТЬ ПО
	ПланБюджетаРССрезПоследних.Статья,
	ФактБюджета.Статья,
	ЕСТЬNULL(ФактБюджета.Месяц, ПланБюджетаРССрезПоследних.Период),
	ВЫБОР
		КОГДА ПланБюджетаРССрезПоследних.Статья ЕСТЬ NULL
			ТОГДА ФактБюджета.Статья.Обязательная
		ИНАЧЕ ПланБюджетаРССрезПоследних.Статья.Обязательная
	КОНЕЦ</query>
